# ── Google Document AI ──────────────────────────────────────────────────────
DOC_AI_PROJECT_ID=your-gcp-project-id
DOC_AI_LOCATION=eu
DOC_AI_PROCESSOR_ID=your-document-ai-processor-id
DOC_AI_MIME_TYPE=application/pdf
DOC_AI_FIELD_MASK=text,entities,fund name, amount

# ── Upload limits ────────────────────────────────────────────────────────────
# Default is 15 MB. Value is in bytes.
MAX_PARSE_UPLOAD_BYTES=15728640

# ── Authentication credentials ───────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY — not needed (or recommended) on Cloud Run.
# On Cloud Run, attach a service account with roles/documentai.apiUser instead.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── Optional: Azure push ─────────────────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=...;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
