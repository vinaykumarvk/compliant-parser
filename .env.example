# ── Operator authentication ──────────────────────────────────────────────────
APP_ADMIN_USERNAME=operator
APP_ADMIN_PASSWORD=change-me
APP_SESSION_SECRET=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-separate-long-random-jwt-secret
IQW_ALLOW_INSECURE_DEV_SECRET=false
# APP_SESSION_HTTPS_ONLY=true

# ── OCR boundary ────────────────────────────────────────────────────────────
# RFQ-compliant deployments should use IQW_OCR_PROVIDER=self_hosted. Google
# Document AI is an external fallback and requires written approval metadata in
# production.
IQW_OCR_PROVIDER=auto
IQW_SELF_HOSTED_OCR_URL=
IQW_SELF_HOSTED_OCR_API_KEY=
IQW_SELF_HOSTED_OCR_TIMEOUT=120
IQW_OCR_FALLBACK_PROVIDER=

# ── Google Document AI fallback ─────────────────────────────────────────────
# Use an OCR / handwriting-capable processor because complaints may be
# handwritten and may contain English, Hindi, Urdu, or Telugu text.
DOC_AI_PROJECT_ID=your-gcp-project-id
DOC_AI_LOCATION=eu
DOC_AI_PROCESSOR_ID=your-document-ai-processor-id
DOC_AI_PROCESSOR_VERSION_ID=
# DOC_AI_MIME_TYPE is auto-detected for web uploads (PDF, DOCX, images).
# Only used by the standalone batch CLI path. Default: application/pdf
DOC_AI_MIME_TYPE=application/pdf
DOC_AI_FIELD_MASK=text

# ── Structured LLM workflows ────────────────────────────────────────────────
# RFQ-compliant deployments should use IQW_LLM_PROVIDER=self_hosted. OpenAI or
# Gemini are external fallbacks and require written approval metadata in
# production.
IQW_LLM_PROVIDER=auto
IQW_SELF_HOSTED_LLM_URL=
IQW_SELF_HOSTED_LLM_API_KEY=
IQW_SELF_HOSTED_LLM_MODEL=llama3-legal-local
IQW_LLM_MODEL=gpt-5.2
IQW_GEMINI_MODEL=gemini-2.5-flash
IQW_ALLOW_LLM_STUBS=false
# Automatically run BNS section recommendation on every document upload.
IQW_AUTO_BNS_RECOMMENDATION=true

# ── Knowledge Intelligence Service integration ─────────────────────────────
# Optional. When enabled and fully configured, section recommendation prefers
# KIS BNS reasoning and falls back to the configured LLM path when unavailable.
IQW_KIS_ENABLED=false
IQW_KIS_BASE_URL=http://127.0.0.1:8090
IQW_KIS_API_KEY=
IQW_KIS_DOMAIN=police-iqw
IQW_KIS_KB=
IQW_KIS_KB_POLICY=
IQW_KIS_KB_CASES=
IQW_KIS_PROVIDER=self_hosted
IQW_KIS_MODEL=llama3-legal-local
IQW_KIS_TIMEOUT_SECONDS=20
IQW_KIS_FALLBACK_ON_ERROR=true
IQW_KIS_BACKGROUND_INDEXING=true
IQW_KIS_WORKER_POLL_SECONDS=5
IQW_KIS_WORKER_LOCK_SECONDS=900
IQW_KIS_MAX_RETRIES=5
IQW_KIS_RETRY_BASE_SECONDS=60
IQW_KIS_RETRY_MAX_SECONDS=3600
IQW_KIS_AUTO_PUBLISH_SNAPSHOT=false

# ── LLM privacy boundary ───────────────────────────────────────────────────
# All outbound LLM prompts are PII-tokenized before the request is sent. Raw
# values are encrypted in memory and restored only after the response returns.
# Use a long random value or a Fernet key; production requires this setting.
IQW_PII_ENCRYPTION_KEY=
IQW_LLM_PRIVACY_STRICT=true
IQW_PII_MASK_NAMES=true

# ── External AI written approval gate ───────────────────────────────────────
# Required in production before any Google/OpenAI/Gemini provider can process
# case data. Keep these blank for strict self-hosted-only deployments.
IQW_REQUIRE_EXTERNAL_AI_APPROVAL=false
EXTERNAL_AI_API_APPROVED=false
EXTERNAL_AI_APPROVAL_ID=
EXTERNAL_AI_APPROVED_BY=
EXTERNAL_AI_APPROVAL_EXPIRES_ON=
EXTERNAL_AI_APPROVAL_SCOPE=

# ── Translation to English ───────────────────────────────────────────────────
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=auto
TRANSLATION_FALLBACK_PROVIDER=openai
TRANSLATION_PROJECT_ID=your-gcp-project-id
TRANSLATION_LOCATION=global
TRANSLATION_TARGET_LANGUAGE=en
OPENAI_TRANSLATION_ENABLED=true
OPENAI_TRANSLATION_MODEL=gpt-5.2
OPENAI_TRANSLATION_REASONING_EFFORT=none
# Set to false to skip the additional grammar/spelling cleanup pass.
TRANSLATION_REFINEMENT_ENABLED=true
TRANSLATION_REFINEMENT_PROVIDER=openai
TRANSLATION_REFINEMENT_REASONING_EFFORT=medium
# TRANSLATION_REFINEMENT_MODEL=gpt-5.2
# OPENAI_API_KEY=sk-...
# OPENAI_TRANSLATION_BASE_URL=https://api.openai.com/v1

# ── Gemini Translation ────────────────────────────────────────────────────
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_TRANSLATION_MODEL=gemini-2.5-flash

# ── External government / platform interfaces ───────────────────────────────
HRMS_AUTH_URL=
CCTNS_SYNC_URL=
DSC_TOKEN_PRESENT=false
DSC_CERT_SUBJECT=
DSC_CERT_SERIAL=
DSC_PROVIDER=
OBJECT_STORAGE_PROVIDER=auto
OBJECT_STORAGE_BUCKET=
GCS_BUCKET=
OBJECT_STORAGE_KMS_KEY=
OBJECT_STORAGE_LOCAL_DIR=.object-storage
# On-prem S3-compatible object storage, e.g. MinIO.
S3_ENDPOINT_URL=
S3_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_KMS_KEY_ID=
NOTIFICATION_GATEWAY_URL=

# ── Search, vector, and async job backplanes ────────────────────────────────
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
PGVECTOR_ENABLED=true
REDIS_URL=redis://localhost:6379/0
IQW_JOB_BACKEND=redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=default

# ── Senior dashboard background jobs ───────────────────────────────────────
# In-process worker for dashboard export and snapshot jobs. Keep enabled for
# Cloud Run/manual deployments; a distributed worker can reuse the same queued
# job records later.
IQW_DASHBOARD_BACKGROUND_WORKER=true
IQW_DASHBOARD_WORKER_POLL_SECONDS=5

# ── Translation Quality Estimation ────────────────────────────────────────
# TRANSLATION_QE_ENABLED=false
# TRANSLATION_QE_THRESHOLD=0.7

# ── Upload limits ────────────────────────────────────────────────────────────
# Default is 15 MB. Value is in bytes.
MAX_PARSE_UPLOAD_BYTES=15728640

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty to disable CORS middleware.
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ── Rate limiting ───────────────────────────────────────────────────────────
# Max requests per minute per IP for write endpoints. Default is 30.
# RATE_LIMIT_RPM=30

# ── Authentication credentials for Google APIs ──────────────────────────────
# LOCAL DEVELOPMENT ONLY — not needed (or recommended) on Cloud Run when using
# an attached service account.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── RAG-app policy sync ─────────────────────────────────────────────────────
# Connection to the RAG-app PostgreSQL database for syncing policy documents
# into the KIS Policy knowledge base. Only needed if policy sync is used.
# IQW_RAGAPP_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/police_kb

# ── Database (required for parse history) ───────────────────────────────────
# Provide exactly one connection path.
#
# LOCAL DEV: direct asyncpg connection string (for local Postgres or Cloud SQL proxy)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/police_complaints
#
# CLOUD RUN: Cloud SQL Python Connector with IAM auth
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_NAME=police_complaints
