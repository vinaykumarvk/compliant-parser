# ── Operator authentication ──────────────────────────────────────────────────
APP_ADMIN_USERNAME=operator
APP_ADMIN_PASSWORD=change-me
APP_SESSION_SECRET=replace-with-a-long-random-secret
# APP_SESSION_HTTPS_ONLY=true

# ── Google Document AI ──────────────────────────────────────────────────────
# Use an OCR / handwriting-capable processor because complaints may be handwritten
# and may contain English, Hindi, or Telugu text.
DOC_AI_PROJECT_ID=your-gcp-project-id
DOC_AI_LOCATION=eu
DOC_AI_PROCESSOR_ID=your-document-ai-processor-id
# DOC_AI_MIME_TYPE is auto-detected for web uploads (PDF, DOCX, images).
# Only used by the standalone batch CLI path. Default: application/pdf
DOC_AI_MIME_TYPE=application/pdf
DOC_AI_FIELD_MASK=text

# ── Translation to English ───────────────────────────────────────────────────
TRANSLATION_ENABLED=true
TRANSLATION_PROVIDER=auto
TRANSLATION_FALLBACK_PROVIDER=openai
TRANSLATION_PROJECT_ID=your-gcp-project-id
TRANSLATION_LOCATION=global
TRANSLATION_TARGET_LANGUAGE=en
OPENAI_TRANSLATION_ENABLED=true
OPENAI_TRANSLATION_MODEL=gpt-5.2
OPENAI_TRANSLATION_REASONING_EFFORT=none
# OPENAI_API_KEY=sk-...
# OPENAI_TRANSLATION_BASE_URL=https://api.openai.com/v1

# ── Upload limits ────────────────────────────────────────────────────────────
# Default is 15 MB. Value is in bytes.
MAX_PARSE_UPLOAD_BYTES=15728640

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave empty to disable CORS middleware.
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com

# ── Rate limiting ───────────────────────────────────────────────────────────
# Max requests per minute per IP for write endpoints. Default is 30.
# RATE_LIMIT_RPM=30

# ── Authentication credentials for Google APIs ──────────────────────────────
# LOCAL DEVELOPMENT ONLY — not needed (or recommended) on Cloud Run when using
# an attached service account.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ── Database (required for parse history) ───────────────────────────────────
# Provide exactly one connection path.
#
# LOCAL DEV: direct asyncpg connection string (for local Postgres or Cloud SQL proxy)
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/police_complaints
#
# CLOUD RUN: Cloud SQL Python Connector with IAM auth
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_NAME=police_complaints
