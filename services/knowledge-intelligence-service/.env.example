KIS_SERVICE_NAME=knowledge-intelligence-service
KIS_API_PREFIX=/api/v1

# Direct local/proxy DB URL, or Cloud SQL connector settings below. In Cloud
# Run, KIS_DATABASE_URL or DATABASE_URL can be sourced from Secret Manager
# secret: police-kb-database-url. postgresql:// URLs are normalized to asyncpg.
KIS_DATABASE_URL=
KIS_CLOUD_SQL_CONNECTION_NAME=policing-apps:asia-southeast1:policing-db-v2
KIS_DB_NAME=police_kb
KIS_DB_USER=puda
KIS_DB_PASSWORD=
KIS_DB_IAM_AUTH=false
KIS_AUTO_MIGRATE=true
KIS_REQUIRE_DATABASE=true

KIS_AUTH_DISABLED=false
KIS_API_KEYS={"local-dev-key":{"principal_id":"local-admin","domain_id":"police-iqw","scopes":["domain:admin","kb:write","kb:read","llm:execute"]}}
KIS_CORS_ORIGINS=http://localhost:8080
KIS_SECRET_KEY=replace-with-a-long-random-secret
KIS_PII_STRICT=true
KIS_EMBEDDING_DIMENSIONS=32
KIS_DEFAULT_PROVIDER=self_hosted
KIS_ALLOWED_MODELS=self_hosted:llama3-legal-local,openai:gpt-5.2,gemini:gemini-2.5-flash
KIS_SELF_HOSTED_LLM_URL=
KIS_SELF_HOSTED_LLM_API_KEY=
KIS_LLM_TIMEOUT_SECONDS=120
KIS_ALLOW_LLM_STUBS=false
KIS_OPENAI_API_KEY=
KIS_OPENAI_BASE_URL=https://api.openai.com/v1
KIS_GEMINI_API_KEY=
KIS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
